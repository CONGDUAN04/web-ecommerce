generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model User {
  id          Int         @id @default(autoincrement())
  username    String      @unique
  password    String?
  fullName    String?
  phone       String?
  avatar      String?
  avatarId    String?
  accountType AccountType @default(SYSTEM)
  roleId      Int?

  lastLoginAt       DateTime?
  passwordChangedAt DateTime?

  isVerified Boolean @default(false)

  otp        String?
  otpExpire  DateTime?
  otpType    OtpType?
  otpSentAt  DateTime?
  otpAttempt Int       @default(0)

  createdAt DateTime  @default(now())
  isActive  Boolean   @default(true)
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  addresses      Address[]
  cart           Cart?
  notifications  Notification[]
  orders         Order[]
  returnRequests ReturnRequest[]
  reviews        Review[]
  reviewReplies  ReviewReply[]
  sessions       Session[]
  role           Role?           @relation(fields: [roleId], references: [id])
  voucherUsages  VoucherUsage[]
  wishlists      Wishlist[]

  @@index([roleId])
  @@index([phone])
  @@index([accountType])
  @@index([createdAt])
  @@index([deletedAt])
}

model Session {
  id           Int      @id @default(autoincrement())
  refreshToken String   @unique @db.VarChar(500)
  userAgent    String?
  ipAddress    String?
  isRevoked    Boolean  @default(false)
  expiresAt    DateTime
  userId       Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRevoked])
  @@index([expiresAt])
}

model Address {
  id        Int      @id @default(autoincrement())
  fullName  String
  phone     String
  address   String
  province  String?
  district  String?
  ward      String?
  isDefault Boolean  @default(false)
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isDefault])
}

model Category {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  slug          String         @unique
  icon          String?
  iconId        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  products      Product[]
  productGroups ProductGroup[]
}

model Brand {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  slug          String         @unique
  logo          String?
  logoId        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  products      Product[]
  productGroups ProductGroup[]
}

model ProductGroup {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  series      String?
  description String?
  thumbnail   String?
  thumbnailId String?
  isActive    Boolean   @default(true)
  brandId     Int
  categoryId  Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
  brand       Brand     @relation(fields: [brandId], references: [id])
  category    Category  @relation(fields: [categoryId], references: [id])

  @@index([brandId])
  @@index([categoryId])
  @@index([isActive])
  @@index([series])
}

model Product {
  id             Int                    @id @default(autoincrement())
  name           String
  slug           String                 @unique
  storage        Int?
  description    String?                @db.Text
  thumbnail      String?
  thumbnailId    String?
  viewCount      Int                    @default(0)
  isActive       Boolean                @default(true)
  groupId        Int
  brandId        Int
  categoryId     Int
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  deletedAt      DateTime?
  brand          Brand                  @relation(fields: [brandId], references: [id])
  category       Category               @relation(fields: [categoryId], references: [id])
  group          ProductGroup           @relation(fields: [groupId], references: [id])
  images         ProductImage[]
  specifications ProductSpecification[]
  reviews        Review[]
  variants       Variant[]
  wishlists      Wishlist[]

  @@index([groupId])
  @@index([brandId])
  @@index([categoryId])
  @@index([isActive])
  @@index([storage])
  @@index([viewCount])
  @@index([createdAt])
  @@index([isActive, categoryId])
  @@index([isActive, brandId])
  @@index([isActive, groupId])
  @@index([groupId, storage])
}

model Variant {
  id             Int             @id @default(autoincrement())
  sku            String          @unique
  color          String
  price          Int
  comparePrice   Int?
  quantity       Int             @default(0)
  sold           Int             @default(0)
  isActive       Boolean         @default(true)
  productId      Int
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  cartItems      CartItem[]
  flashSaleItems FlashSaleItem[]
  inventoryLogs  InventoryLog[]
  orderItems     OrderItem[]
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([price])
  @@index([isActive])
  @@index([productId, isActive])
  @@index([productId, color])
  @@index([productId, price])
}

model ProductImage {
  id         Int      @id @default(autoincrement())
  imageUrl   String
  imageUrlId String
  sortOrder  Int      @default(0)
  productId  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductSpecification {
  id        Int      @id @default(autoincrement())
  name      String
  value     String
  productId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int        @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cartItems CartItem[]
}

model CartItem {
  id        Int      @id @default(autoincrement())
  quantity  Int
  price     Int
  cartId    Int
  variantId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant   Variant  @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@index([cartId])
  @@index([variantId])
}

model Order {
  id              Int            @id @default(autoincrement())
  subtotal        Int
  discountAmount  Int            @default(0)
  shippingFee     Int            @default(0)
  finalPrice      Int
  receiverName    String
  receiverPhone   String
  receiverAddress String
  note            String?
  cancelReason    String?
  trackingCode    String?
  status          OrderStatus    @default(PENDING)
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus  @default(PENDING)
  userId          Int
  voucherId       Int?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id])
  voucher         Voucher?       @relation(fields: [voucherId], references: [id])
  orderItems      OrderItem[]
  payment         Payment?
  returnRequest   ReturnRequest?
  voucherUsages   VoucherUsage?

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([voucherId])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([createdAt])
}

model OrderItem {
  id             Int          @id @default(autoincrement())
  productName    String
  thumbnail      String?
  variantColor   String
  variantStorage Int?
  variantSku     String
  quantity       Int
  price          Int
  orderId        Int
  variantId      Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant        Variant      @relation(fields: [variantId], references: [id])
  returnItems    ReturnItem[]

  @@index([orderId])
  @@index([variantId])
}

model Payment {
  id            Int           @id @default(autoincrement())
  amount        Int
  provider      PaymentMethod
  status        PaymentStatus
  transactionId String?
  refundAmount  Int?
  refundId      String?
  refundNote    String?
  orderId       Int           @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([transactionId])
}

model ReturnRequest {
  id           Int              @id @default(autoincrement())
  reason       ReturnReason
  note         String?          @db.Text
  adminNote    String?
  refundAmount Int?
  isApproved   Boolean?
  resolvedAt   DateTime?
  orderId      Int              @unique
  userId       Int
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  evidences    ReturnEvidence[]
  returnItems  ReturnItem[]
  order        Order            @relation(fields: [orderId], references: [id])
  user         User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isApproved])
  @@index([createdAt])
}

model ReturnEvidence {
  id              Int           @id @default(autoincrement())
  url             String
  publicId        String
  type            String?
  returnRequestId Int
  createdAt       DateTime      @default(now())
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  @@index([returnRequestId])
}

model ReturnItem {
  id              Int           @id @default(autoincrement())
  quantity        Int
  reason          String?
  isRestockable   Boolean       @default(true)
  returnRequestId Int
  orderItemId     Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  orderItem       OrderItem     @relation(fields: [orderItemId], references: [id])
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  @@index([returnRequestId])
  @@index([orderItemId])
}

model Voucher {
  id                   Int            @id @default(autoincrement())
  code                 String         @unique
  type                 VoucherType
  discount             Int
  maxDiscount          Int?
  minOrderValue        Int?
  startDate            DateTime
  endDate              DateTime
  usageLimit           Int?
  usagePerUser         Int?
  usedCount            Int            @default(0)
  isActive             Boolean        @default(true)
  applicableCategoryId Int?
  applicableBrandId    Int?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  orders               Order[]
  voucherUsages        VoucherUsage[]

  @@index([code])
  @@index([isActive])
  @@index([startDate, endDate])
}

model VoucherUsage {
  id        Int      @id @default(autoincrement())
  userId    Int
  voucherId Int
  orderId   Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order    @relation(fields: [orderId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  voucher   Voucher  @relation(fields: [voucherId], references: [id])

  @@unique([userId, voucherId, orderId])
  @@index([userId, voucherId])
  @@index([voucherId])
}

model InventoryLog {
  id              Int             @id @default(autoincrement())
  action          InventoryAction
  quantity        Int
  quantityBefore  Int
  quantityAfter   Int
  note            String?
  variantId       Int
  returnRequestId Int?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  variant         Variant         @relation(fields: [variantId], references: [id])

  @@index([variantId])
  @@index([action])
  @@index([variantId, createdAt])
  @@index([returnRequestId])
}

model Review {
  id                 Int           @id @default(autoincrement())
  rating             Int
  comment            String?       @db.Text
  isHidden           Boolean       @default(false)
  isVerifiedPurchase Boolean       @default(false)
  productId          Int
  userId             Int
  createdAt          DateTime      @default(now())
  product            Product       @relation(fields: [productId], references: [id])
  user               User          @relation(fields: [userId], references: [id])
  images             ReviewImage[]
  replies            ReviewReply[]

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
  @@index([productId, rating])
  @@index([productId, isHidden, createdAt])
  @@index([isVerifiedPurchase])
}

model ReviewImage {
  id         Int    @id @default(autoincrement())
  imageUrl   String
  imageUrlId String
  reviewId   Int
  review     Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

model ReviewReply {
  id        Int      @id @default(autoincrement())
  comment   String   @db.Text
  reviewId  Int
  userId    Int
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([reviewId])
  @@index([userId])
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId], map: "Wishlist_productId_fkey")
}

model FlashSale {
  id        Int             @id @default(autoincrement())
  name      String
  startTime DateTime
  endTime   DateTime
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     FlashSaleItem[]

  @@index([isActive])
  @@index([startTime, endTime])
}

model FlashSaleItem {
  id          Int       @id @default(autoincrement())
  salePrice   Int
  quantity    Int
  sold        Int       @default(0)
  flashSaleId Int
  variantId   Int
  flashSale   FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  variant     Variant   @relation(fields: [variantId], references: [id])

  @@unique([flashSaleId, variantId])
  @@index([flashSaleId])
  @@index([variantId])
}

model Notification {
  id        Int              @id @default(autoincrement())
  title     String
  content   String
  link      String?
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false)
  userId    Int
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model Banner {
  id        Int      @id @default(autoincrement())
  title     String?
  image     String
  imageId   String
  link      String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

model Slider {
  id        Int      @id @default(autoincrement())
  image     String
  imageId   String
  title     String?
  subTitle  String?
  link      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

enum AccountType {
  SYSTEM
  GOOGLE
  GITHUB
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPING
  COMPLETED
  CANCELLED
  RETURN_REQUESTED
  RETURN_APPROVED
  RETURNED
}

enum PaymentMethod {
  COD
  VNPAY
  PAYPAL
  MOMO
  BANKING
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum VoucherType {
  PERCENT
  FIXED
}

enum InventoryAction {
  IMPORT
  EXPORT
  ADJUST
  RETURN
}

enum NotificationType {
  ORDER
  PROMOTION
  SYSTEM
  RETURN
}

enum ReturnReason {
  WRONG_PRODUCT
  DEFECTIVE
  NOT_AS_DESCRIBED
  CHANGED_MIND
  OTHER
}

enum OtpType {
  VERIFY_EMAIL
  RESET_PASSWORD
}
