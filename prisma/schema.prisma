generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  // url      = env("DATABASE_URL")
}

// ========================
// ENUMS
// ========================

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPING
  COMPLETED
  CANCELLED
  RETURNED
}

enum PaymentMethod {
  COD
  VNPAY
  PAYPAL
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum VoucherType {
  PERCENT
  FIXED
}

enum InventoryAction {
  IMPORT
  EXPORT
  ADJUST
}

enum NotificationType {
  ORDER
  PROMOTION
  SYSTEM
}

enum AccountType {
  SYSTEM
  GOOGLE
  GITHUB
}

// ========================
// USER & AUTH
// ========================

model Role {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  users       User[]

  createdAt DateTime @default(now())
}

model Session {
  id           Int      @id @default(autoincrement())
  refreshToken String   @unique @db.VarChar(500)
  userAgent    String?
  ipAddress    String?
  isRevoked    Boolean  @default(false)
  expiresAt    DateTime

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([refreshToken])
  @@index([userId, isRevoked])
  @@index([expiresAt])
}

model User {
  id       Int     @id @default(autoincrement())
  username String  @unique
  password String?

  fullName    String?
  phone       String?
  avatar      String?
  accountType AccountType @default(SYSTEM)

  roleId Int?
  role   Role? @relation(fields: [roleId], references: [id])

  cart          Cart?
  orders        Order[]
  reviews       Review[]
  reviewReplies ReviewReply[]
  wishlists     Wishlist[]
  addresses     Address[]
  notifications Notification[]
  voucherUsages VoucherUsage[]
  sessions      Session[]

  createdAt DateTime @default(now())

  @@index([roleId])
  @@index([phone])
  @@index([createdAt])
  @@index([accountType])
}

model Address {
  id Int @id @default(autoincrement())

  fullName String
  phone    String
  address  String
  province String?
  district String?
  ward     String?

  isDefault Boolean @default(false)

  userId Int
  user   User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, isDefault])
}

// ========================
// PRODUCT
// ========================

model ProductGroup {
  id          Int     @id @default(autoincrement())
  name        String // "iPhone 17 Pro Max"
  slug        String  @unique
  series      String? // "iPhone 17" — gom nhóm nhiều model cùng dòng
  description String?
  thumbnail   String?
  isActive    Boolean @default(true)

  brandId    Int
  categoryId Int

  brand    Brand    @relation(fields: [brandId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([brandId])
  @@index([categoryId])
  @@index([series])
  @@index([brandId, series]) // lọc dòng SP của 1 brand
}

model Category {
  id   Int    @id @default(autoincrement())
  name String @unique
  slug String @unique

  products      Product[]
  productGroups ProductGroup[]

  createdAt DateTime @default(now())
}

model Brand {
  id   Int     @id @default(autoincrement())
  name String  @unique
  slug String  @unique
  logo String?

  products      Product[]
  productGroups ProductGroup[]

  createdAt DateTime @default(now())
}

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  slug        String  @unique
  storage     Int // GB: 256, 512, 1024, 2048
  description String? @db.Text
  thumbnail   String?

  brandId    Int // tự fill từ group khi tạo
  categoryId Int // tự fill từ group khi tạo
  groupId    Int // bắt buộc — không còn optional

  brand    Brand        @relation(fields: [brandId], references: [id])
  category Category     @relation(fields: [categoryId], references: [id])
  group    ProductGroup @relation(fields: [groupId], references: [id])

  variants       Variant[]
  images         ProductImage[]
  specifications ProductSpecification[]
  reviews        Review[]
  wishlists      Wishlist[]

  viewCount Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([categoryId])
  @@index([groupId])
  @@index([isActive])
  @@index([storage])
  @@index([isActive, categoryId])
  @@index([isActive, brandId])
  @@index([isActive, groupId])
  @@index([isActive, storage])
  @@index([viewCount])
  @@index([createdAt])
  @@index([groupId, storage])
}

model Variant {
  id  Int    @id @default(autoincrement())
  sku String @unique

  color String // "Cam Vũ Trụ"

  price        Int
  comparePrice Int?

  quantity Int     @default(0)
  sold     Int     @default(0)
  isActive Boolean @default(true)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  cartItems      CartItem[]
  orderItems     OrderItem[]
  inventoryLogs  InventoryLog[]
  imeis          Imei[]
  flashSaleItems FlashSaleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([price])
  @@index([color])
  @@index([isActive])
  @@index([productId, isActive])
  @@index([productId, color]) // nhóm theo màu
  @@index([productId, price])
}

model Imei {
  id   Int    @id @default(autoincrement())
  code String @unique

  isSold Boolean @default(false)

  variantId Int
  variant   Variant @relation(fields: [variantId], references: [id])

  orderItemId Int?       @unique
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id])

  createdAt DateTime @default(now())

  @@index([variantId])
  @@index([isSold])
  @@index([variantId, isSold])
}

model ProductImage {
  id        Int    @id @default(autoincrement())
  imageUrl  String
  sortOrder Int    @default(0)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductSpecification {
  id    Int    @id @default(autoincrement())
  name  String // "Kích thước màn hình"
  value String // "6.9 inch"

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ========================
// CART
// ========================

model Cart {
  id Int @id @default(autoincrement())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  cartItems CartItem[]

  createdAt DateTime @default(now())
}

model CartItem {
  id Int @id @default(autoincrement())

  quantity Int
  price    Int

  cartId    Int
  variantId Int

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@index([cartId])
  @@index([variantId])
}

// ========================
// ORDER
// ========================

model Order {
  id Int @id @default(autoincrement())

  totalPrice     Int
  discountAmount Int @default(0)
  shippingFee    Int @default(0)
  finalPrice     Int

  receiverName    String
  receiverPhone   String
  receiverAddress String

  note           String?
  cancelReason   String?
  trackingCode   String?
  shippingMethod String?

  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)

  confirmedAt DateTime?
  shippedAt   DateTime?
  completedAt DateTime?
  cancelledAt DateTime?

  userId    Int
  voucherId Int?

  user    User     @relation(fields: [userId], references: [id])
  voucher Voucher? @relation(fields: [voucherId], references: [id])

  orderItems    OrderItem[]
  payments      Payment[]
  voucherUsages VoucherUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([paymentStatus])
  @@index([voucherId])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id Int @id @default(autoincrement())

  quantity Int
  price    Int

  productName String
  variantInfo String // "Cam Vũ Trụ - 256GB"
  thumbnail   String?

  orderId   Int
  variantId Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id])

  imei Imei?

  @@index([orderId])
  @@index([variantId])
}

model Payment {
  id Int @id @default(autoincrement())

  amount        Int
  provider      PaymentMethod
  status        PaymentStatus
  transactionId String?

  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([status])
  @@index([transactionId])
}

// ========================
// VOUCHER
// ========================

model Voucher {
  id   Int    @id @default(autoincrement())
  code String @unique

  type VoucherType

  discount      Int
  maxDiscount   Int?
  minOrderValue Int?

  startDate DateTime
  endDate   DateTime

  usageLimit   Int?
  usagePerUser Int?
  usedCount    Int  @default(0)

  isActive Boolean @default(true)

  orders        Order[]
  voucherUsages VoucherUsage[]

  @@index([startDate, endDate])
  @@index([isActive])
}

model VoucherUsage {
  id Int @id @default(autoincrement())

  userId    Int
  voucherId Int
  orderId   Int @unique

  user    User    @relation(fields: [userId], references: [id])
  voucher Voucher @relation(fields: [voucherId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, voucherId, orderId])
  @@index([userId, voucherId])
  @@index([voucherId])
}

// ========================
// INVENTORY
// ========================

model InventoryLog {
  id Int @id @default(autoincrement())

  action         InventoryAction
  quantity       Int
  quantityBefore Int
  quantityAfter  Int
  note           String?

  variantId Int
  variant   Variant @relation(fields: [variantId], references: [id])

  createdAt DateTime @default(now())

  @@index([variantId])
  @@index([action])
  @@index([variantId, createdAt])
}

// ========================
// REVIEW
// ========================

model Review {
  id Int @id @default(autoincrement())

  rating   Int
  comment  String? @db.Text
  isHidden Boolean @default(false)

  productId Int
  userId    Int

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  images  ReviewImage[]
  replies ReviewReply[]

  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
  @@index([productId, rating])
  @@index([productId, isHidden, createdAt])
}

model ReviewImage {
  id       Int    @id @default(autoincrement())
  imageUrl String

  reviewId Int
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

model ReviewReply {
  id      Int    @id @default(autoincrement())
  comment String @db.Text

  reviewId Int
  userId   Int

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([reviewId])
  @@index([userId])
}

// ========================
// WISHLIST
// ========================

model Wishlist {
  id Int @id @default(autoincrement())

  userId    Int
  productId Int

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// ========================
// FLASH SALE
// ========================

model FlashSale {
  id        Int      @id @default(autoincrement())
  name      String
  startTime DateTime
  endTime   DateTime
  isActive  Boolean  @default(true)

  items FlashSaleItem[]

  createdAt DateTime @default(now())

  @@index([isActive])
  @@index([startTime, endTime])
}

model FlashSaleItem {
  id        Int @id @default(autoincrement())
  salePrice Int
  quantity  Int
  sold      Int @default(0)

  flashSaleId Int
  variantId   Int

  flashSale FlashSale @relation(fields: [flashSaleId], references: [id])
  variant   Variant   @relation(fields: [variantId], references: [id])

  @@unique([flashSaleId, variantId])
  @@index([flashSaleId])
  @@index([variantId])
}

// ========================
// NOTIFICATION
// ========================

model Notification {
  id      Int              @id @default(autoincrement())
  title   String
  content String
  link    String?
  type    NotificationType @default(SYSTEM)
  isRead  Boolean          @default(false)

  userId Int
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ========================
// UI / CMS
// ========================

model Banner {
  id    Int     @id @default(autoincrement())
  title String?
  image String
  link  String?

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())

  @@index([isActive])
}

model Slider {
  id       Int     @id @default(autoincrement())
  image    String
  title    String?
  subTitle String?
  link     String?

  sortOrder Int @default(0)

  createdAt DateTime @default(now())

  @@index([sortOrder])
}
