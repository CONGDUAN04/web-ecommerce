generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  // url      = env("DATABASE_URL")
}

// ========================
// ENUMS
// ========================

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPING
  COMPLETED
  CANCELLED
  RETURNED
}

enum PaymentMethod {
  COD
  VNPAY
  PAYPAL
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum VoucherType {
  PERCENT
  FIXED
}

enum InventoryAction {
  IMPORT
  EXPORT
  ADJUST
}

enum NotificationType {
  ORDER
  PROMOTION
  SYSTEM
}

enum AccountType {
  SYSTEM
  GOOGLE
  GITHUB
}

// ========================
// USER & AUTH
// ========================

model Role {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  users       User[]

  createdAt DateTime @default(now())
}

model Session {
  id           Int      @id @default(autoincrement())
  refreshToken String   @unique @db.VarChar(500)
  userAgent    String? // trình duyệt / thiết bị
  ipAddress    String? // IP đăng nhập
  isRevoked    Boolean  @default(false)
  expiresAt    DateTime // thời hạn refresh token

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([refreshToken])
  @@index([userId, isRevoked]) // lấy session còn hiệu lực của user
  @@index([expiresAt]) // dọn session hết hạn
}

model User {
  id       Int     @id @default(autoincrement())
  username String  @unique
  password String?

  fullName    String?
  phone       String?
  avatar      String?
  accountType AccountType @default(SYSTEM)

  roleId Int?
  role   Role? @relation(fields: [roleId], references: [id])

  cart          Cart?
  orders        Order[]
  reviews       Review[]
  reviewReplies ReviewReply[]
  wishlists     Wishlist[]
  addresses     Address[]
  notifications Notification[]
  voucherUsages VoucherUsage[]

  createdAt DateTime  @default(now())
  sessions  Session[]

  @@index([roleId])
  @@index([phone]) // tìm user theo SĐT
  @@index([createdAt]) // admin sort danh sách user
  @@index([accountType]) // filter user theo loại tài khoản
}

model Address {
  id Int @id @default(autoincrement())

  fullName String
  phone    String
  address  String
  province String?
  district String?
  ward     String?

  isDefault Boolean @default(false)

  userId Int
  user   User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, isDefault]) // lấy địa chỉ mặc định nhanh
}

// ========================
// PRODUCT
// ========================

model ProductGroup {
  id          Int     @id @default(autoincrement())
  name        String
  slug        String  @unique
  description String?
  thumbnail   String?
  isActive    Boolean @default(true)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model Category {
  id   Int    @id @default(autoincrement())
  name String @unique
  slug String @unique

  parentId Int?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  products Product[]

  createdAt DateTime @default(now())

  @@index([parentId])
}

model Brand {
  id   Int     @id @default(autoincrement())
  name String  @unique
  slug String  @unique
  logo String?

  products Product[]

  createdAt DateTime @default(now())
}

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  slug        String  @unique
  description String? @db.Text

  thumbnail String?

  brandId    Int
  categoryId Int
  groupId    Int?

  brand    Brand         @relation(fields: [brandId], references: [id])
  category Category      @relation(fields: [categoryId], references: [id])
  group    ProductGroup? @relation(fields: [groupId], references: [id])

  variants       Variant[]
  images         ProductImage[]
  specifications ProductSpecification[]
  reviews        Review[]
  wishlists      Wishlist[]

  viewCount Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([categoryId])
  @@index([groupId])
  @@index([isActive])
  @@index([isActive, categoryId]) // lọc sản phẩm active theo danh mục
  @@index([isActive, brandId]) // lọc sản phẩm active theo thương hiệu
  @@index([viewCount]) // sort theo lượt xem / phổ biến
  @@index([createdAt]) // sort theo mới nhất
}

model Variant {
  id  Int    @id @default(autoincrement())
  sku String @unique

  color   String
  storage Int

  price        Int
  comparePrice Int?

  quantity Int     @default(0)
  sold     Int     @default(0)
  isActive Boolean @default(true)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  cartItems      CartItem[]
  orderItems     OrderItem[]
  inventoryLogs  InventoryLog[]
  imeis          Imei[]
  flashSaleItems FlashSaleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([price])
  @@index([storage])
  @@index([color])
  @@index([isActive])
  @@index([productId, isActive]) // lấy variant active của 1 sản phẩm
  @@index([productId, price]) // lọc giá trong 1 sản phẩm
}

model Imei {
  id   Int    @id @default(autoincrement())
  code String @unique

  isSold Boolean @default(false)

  variantId Int
  variant   Variant @relation(fields: [variantId], references: [id])

  orderItemId Int?       @unique
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id])

  createdAt DateTime @default(now())

  @@index([variantId])
  @@index([isSold])
  @@index([variantId, isSold]) // tìm IMEI còn hàng của 1 variant
}

model ProductImage {
  id        Int    @id @default(autoincrement())
  imageUrl  String
  sortOrder Int    @default(0)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductSpecification {
  id    Int    @id @default(autoincrement())
  name  String
  value String

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ========================
// CART
// ========================

model Cart {
  id Int @id @default(autoincrement())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  cartItems CartItem[]

  createdAt DateTime @default(now())
}

model CartItem {
  id Int @id @default(autoincrement())

  quantity Int
  price    Int

  cartId    Int
  variantId Int

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@index([cartId])
  @@index([variantId]) // FK thiếu - cần khi xóa variant
}

// ========================
// ORDER
// ========================

model Order {
  id Int @id @default(autoincrement())

  totalPrice     Int
  discountAmount Int @default(0)
  shippingFee    Int @default(0)
  finalPrice     Int

  receiverName    String
  receiverPhone   String
  receiverAddress String

  note           String?
  cancelReason   String?
  trackingCode   String?
  shippingMethod String?

  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)

  confirmedAt DateTime?
  shippedAt   DateTime?
  completedAt DateTime?
  cancelledAt DateTime?

  userId    Int
  voucherId Int?

  user    User     @relation(fields: [userId], references: [id])
  voucher Voucher? @relation(fields: [voucherId], references: [id])

  orderItems    OrderItem[]
  payments      Payment[]
  voucherUsages VoucherUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([paymentStatus]) // lọc đơn theo trạng thái thanh toán
  @@index([voucherId]) // FK index còn thiếu
  @@index([userId, status]) // user xem đơn theo trạng thái
  @@index([userId, createdAt]) // user xem lịch sử đơn theo ngày
  @@index([status, createdAt]) // admin lọc đơn theo trạng thái + thời gian
}

model OrderItem {
  id Int @id @default(autoincrement())

  quantity Int
  price    Int

  // Snapshot thông tin lúc đặt hàng
  productName String
  variantInfo String // vd: "Đen - 128GB"
  thumbnail   String?

  orderId   Int
  variantId Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id])

  imei Imei?

  @@index([orderId])
  @@index([variantId]) // thống kê doanh số theo variant
}

model Payment {
  id Int @id @default(autoincrement())

  amount        Int
  provider      PaymentMethod
  status        PaymentStatus
  transactionId String?

  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([status]) // lọc payment theo trạng thái
  @@index([transactionId]) // tra cứu theo mã giao dịch VNPay/PayPal
}

// ========================
// VOUCHER
// ========================

model Voucher {
  id   Int    @id @default(autoincrement())
  code String @unique

  type VoucherType

  discount      Int
  maxDiscount   Int?
  minOrderValue Int?

  startDate DateTime
  endDate   DateTime

  usageLimit   Int?
  usagePerUser Int?
  usedCount    Int  @default(0)

  isActive Boolean @default(true)

  orders        Order[]
  voucherUsages VoucherUsage[]

  @@index([startDate, endDate])
  @@index([isActive])
}

model VoucherUsage {
  id Int @id @default(autoincrement())

  userId    Int
  voucherId Int
  orderId   Int @unique

  user    User    @relation(fields: [userId], references: [id])
  voucher Voucher @relation(fields: [voucherId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, voucherId, orderId])
  @@index([userId, voucherId])
  @@index([voucherId]) // đếm tổng lượt dùng của 1 voucher
}

// ========================
// INVENTORY
// ========================

model InventoryLog {
  id Int @id @default(autoincrement())

  action   InventoryAction
  quantity Int
  note     String?

  variantId Int
  variant   Variant @relation(fields: [variantId], references: [id])

  createdAt DateTime @default(now())

  @@index([variantId])
  @@index([action]) // lọc theo loại hành động
  @@index([variantId, createdAt]) // xem lịch sử nhập/xuất kho theo thời gian
}

// ========================
// REVIEW
// ========================

model Review {
  id Int @id @default(autoincrement())

  rating   Int
  comment  String? @db.Text
  isHidden Boolean @default(false)

  productId Int
  userId    Int

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  images  ReviewImage[]
  replies ReviewReply[]

  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId]) // xem tất cả review của 1 user
  @@index([productId, rating]) // lọc review theo số sao
  @@index([productId, isHidden, createdAt]) // lấy review hiển thị, sort mới nhất
}

model ReviewImage {
  id       Int    @id @default(autoincrement())
  imageUrl String

  reviewId Int
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

model ReviewReply {
  id      Int    @id @default(autoincrement())
  comment String @db.Text

  reviewId Int
  userId   Int

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([reviewId])
  @@index([userId]) // xem tất cả reply của 1 admin/user
}

// ========================
// WISHLIST
// ========================

model Wishlist {
  id Int @id @default(autoincrement())

  userId    Int
  productId Int

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// ========================
// FLASH SALE
// ========================

model FlashSale {
  id        Int      @id @default(autoincrement())
  name      String
  startTime DateTime
  endTime   DateTime
  isActive  Boolean  @default(true)

  items FlashSaleItem[]

  createdAt DateTime @default(now())

  @@index([isActive])
  @@index([startTime, endTime])
}

model FlashSaleItem {
  id        Int @id @default(autoincrement())
  salePrice Int
  quantity  Int
  sold      Int @default(0)

  flashSaleId Int
  variantId   Int

  flashSale FlashSale @relation(fields: [flashSaleId], references: [id])
  variant   Variant   @relation(fields: [variantId], references: [id])

  @@unique([flashSaleId, variantId])
  @@index([flashSaleId])
  @@index([variantId]) // kiểm tra variant có đang flash sale không
}

// ========================
// NOTIFICATION
// ========================

model Notification {
  id      Int              @id @default(autoincrement())
  title   String
  content String
  link    String?
  type    NotificationType @default(SYSTEM)
  isRead  Boolean          @default(false)

  userId Int
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt]) // lấy thông báo mới nhất của user
}

// ========================
// UI / CMS
// ========================

model Banner {
  id    Int     @id @default(autoincrement())
  title String?
  image String
  link  String?

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())

  @@index([isActive])
}

model Slider {
  id       Int     @id @default(autoincrement())
  image    String
  title    String?
  subTitle String?
  link     String?

  sortOrder Int @default(0)

  createdAt DateTime @default(now())

  @@index([sortOrder])
}
